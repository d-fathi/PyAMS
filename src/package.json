{
  "name": "PyAMS",
  "version": "0.2.0",
  "description": "Python for Analog and Mixed Signals",
  "author": "d.fathi",
  "license": "MIT",
  "main": "main.js",
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "asar": true,
    "appId": "pyams.sf.net",
    "productName": "PyAMS",
    "copyright": "Copyright © 2024-2026 PyAMS. All rights reserved.",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraFiles": [
      {
        "from": "demo",
        "to": "demo"
      },
      {
        "from": "pyams",
        "to": "pyams"
      },
      {
        "from": "python",
        "to": "python"
      }
    ],
    "files": [
      "main.js",
      "form.html",
      "package.json",
      "preload.js",
      "handleEditor.js",
      "handleDialogs.js",
      "handleListSignalsParams.js",
      "handleParam.js",
      "handleExecPyAMS.js",
      "handleGestionLibrary.js",
      "config.js",
      "dialogs/about.html",
      "dialogs/editHtml.html",
      "dialogs/list.html",
      "dialogs/params.html",
      "dialogs/processAnalysis.html",
      "dialogs/editCodePy.html",
      "dialogs/pythonPath.html",
      "editor/editor.html",
      "editor/editor.js",
      "dialogs/logo.png",
      "dialogs/library.html",
      "build/logo_win.ico",
      "build/logo.ico",
      "cad/index.css",
      "data/split.js",
      "data/src/css/index.css",
      "data/src/css/model.css",
      "data/src/css/styles.css",
      "data/src/css/pyCode.css",
      "data/plotly-latest.min.js",
      "data/src/utils/information.js",
      "data/src/utils/ruler.js",
      "data/src/utils/polyline.js",
      "data/src/utils/arc.js",
      "data/src/utils/pin.js",
      "data/src/utils/ioparam.js",
      "data/src/utils/part.js",
      "data/src/utils/net.js",
      "data/src/utils/text.js",
      "data/src/utils/body.js",
      "data/src/utils/toolButton.js",
      "data/src/utils/cursor.js",
      "data/src/utils/controle.js",
      "data/src/utils/cnode.js",
      "data/src/utils/utility.js",
      "data/src/utils/measurement.js",
      "data/src/utils/svg.js",
      "data/src/utils/analysis.js",
      "data/src/utils/plots.js",
      "data/src/utils/codePy.js",
      "data/src/utils/codeHtml.js",
      "data/src/utils/codeSpice.js",
      "data/src/selectElements.js",
      "data/src/designByMouse.js",
      "data/src/grid.js",
      "data/src/shapes.js",
      "data/src/resize.js",
      "data/src/drawing.js",
      "data/src/ListSymbol.js",
      "data/src/ListElements.js",
      "data/ioData.js",
      "data/std.js",
      "cad/images.js",
      "cad/dataHtml.js",
      "cad/index.js",
      "cad/action.js",
      "cad/user.js",
      "cad/files.js",
      "images/arc.svg",
      "images/ellipse.svg",
      "images/rect.svg",
      "images/polyline.svg",
      "images/polygon.svg",
      "images/text.svg",
      "images/end.svg",
      "images/Gnd.svg",
      "images/python.svg",
      "images/label.svg",
      "images/new_project.svg",
      "images/new-file.svg",
      "images/open.svg",
      "images/save.svg",
      "images/saveas.svg",
      "images/copy.svg",
      "images/cut.svg",
      "images/past.svg",
      "images/undo.svg",
      "images/redo.svg",
      "images/zoom-in.svg",
      "images/zoom-out.svg",
      "images/html.svg",
      "images/file.svg",
      "images/flipHorizontal.svg",
      "images/flipVertically.svg",
      "images/rotate.svg",
      "form/tabs-container.js",
      "form/tabs-container.css",
      "form/sidebar.js",
      "form/properties_panel.js",
      "form/properties_panel.css",
      "form/modifiedSelect.js",
      "form/objectInspector.js",
      "form/logo.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
